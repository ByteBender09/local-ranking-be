NODE_ENV=development
PORT=4000
API_PREFIX=api
CORS_ORIGINS=http://localhost:3000

# Postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=location_ranking
DB_SYNCHRONIZE=false
DB_LOGGING=false
DB_POOL_SIZE=20

# JWT
JWT_SECRET=replace-this-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback
GOOGLE_SUCCESS_REDIRECT=http://localhost:3000/login/callback
GOOGLE_FAILURE_REDIRECT=http://localhost:3000/login?error=oauth

# Instagram OAuth (Instagram Basic Display API)
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_CALLBACK_URL=http://localhost:4000/api/auth/instagram/callback
INSTAGRAM_SUCCESS_REDIRECT=http://localhost:3000/me/edit
INSTAGRAM_FAILURE_REDIRECT=http://localhost:3000/me/edit?error=instagram

# Throttling
THROTTLE_TTL=60
THROTTLE_LIMIT=120
