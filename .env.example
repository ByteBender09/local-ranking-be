NODE_ENV=development
PORT=4000
CORS_ORIGINS=http://localhost:3000

# When deployed behind a reverse proxy / load balancer (nginx, AWS ALB, Cloudflare, etc.),
# set this to the number of proxy hops so Express trusts X-Forwarded-* headers and the
# throttler / logger see the real client IP. Set to 0 if exposed directly.
TRUST_PROXY=1

# Postgres — single connection string.
# Format: postgres://user:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://postgres:EseIygyHOKknUaBHTOvwmXUlGxgmkWwT@kodama.proxy.rlwy.net:11834/railway
DB_SSL=false
DB_SYNCHRONIZE=false
DB_LOGGING=false
DB_POOL_SIZE=20

# JWT
JWT_SECRET=fc04d785ac3ecd6cb17bac9121d953be21abbecc160a82a62e91f1fc2822f42cfdfd7e6a170268f09589b2ae2a772ff5d5d336dea808f52637fde60f52160266
JWT_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback
GOOGLE_SUCCESS_REDIRECT=http://localhost:3000/login/callback
GOOGLE_FAILURE_REDIRECT=http://localhost:3000/login?error=oauth

# Instagram OAuth (Instagram Basic Display API)
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
INSTAGRAM_CALLBACK_URL=http://localhost:4000/auth/instagram/callback
INSTAGRAM_SUCCESS_REDIRECT=http://localhost:3000/me/edit
INSTAGRAM_FAILURE_REDIRECT=http://localhost:3000/me/edit?error=instagram

# Throttling — burst & sustained tiers (per IP)
THROTTLE_SHORT_TTL=1
THROTTLE_SHORT_LIMIT=20
THROTTLE_DEFAULT_TTL=60
THROTTLE_DEFAULT_LIMIT=120
THROTTLE_AUTH_TTL=60
THROTTLE_AUTH_LIMIT=10

# Request size limits
BODY_LIMIT=1mb
